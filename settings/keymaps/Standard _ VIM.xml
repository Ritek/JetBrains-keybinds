<keymap version="1" name="Standard + VIM" parent="$default">
  <action id="EditorChooseLookupItem">
    <keyboard-shortcut first-keystroke="enter" />
    <keyboard-shortcut first-keystroke="ctrl y" />
  </action>
  <action id="EditorCloneCaretAbove">
    <keyboard-shortcut first-keystroke="ctrl alt k" />
  </action>
  <action id="EditorCloneCaretBelow">
    <keyboard-shortcut first-keystroke="ctrl alt j" />
  </action>
  <action id="EditorDeleteLine" />
  <action id="EditorDown">
    <keyboard-shortcut first-keystroke="down" />
    <keyboard-shortcut first-keystroke="ctrl n" />
  </action>
  <action id="EditorUp">
    <keyboard-shortcut first-keystroke="up" />
    <keyboard-shortcut first-keystroke="ctrl p" />
  </action>
  <action id="FileChooser.NewFolder">
    <keyboard-shortcut first-keystroke="alt insert" />
  </action>
  <action id="FileChooser.TogglePathBar" />
  <action id="Find">
    <keyboard-shortcut first-keystroke="alt f3" />
    <keyboard-shortcut first-keystroke="ctrl h" />
  </action>
  <action id="GotoClass" />
  <action id="List-selectNextRow">
    <keyboard-shortcut first-keystroke="down" />
    <keyboard-shortcut first-keystroke="ctrl n" />
  </action>
  <action id="List-selectPreviousRow">
    <keyboard-shortcut first-keystroke="up" />
    <keyboard-shortcut first-keystroke="ctrl p" />
  </action>
  <action id="PopupMenu-return">
    <keyboard-shortcut first-keystroke="enter" />
    <keyboard-shortcut first-keystroke="ctrl y" />
  </action>
  <action id="PopupMenu-selectChild">
    <keyboard-shortcut first-keystroke="right" />
    <keyboard-shortcut first-keystroke="ctrl l" />
  </action>
  <action id="PopupMenu-selectNext">
    <keyboard-shortcut first-keystroke="down" />
    <keyboard-shortcut first-keystroke="ctrl n" />
  </action>
  <action id="PopupMenu-selectParent">
    <keyboard-shortcut first-keystroke="left" />
    <keyboard-shortcut first-keystroke="ctrl h" />
  </action>
  <action id="PopupMenu-selectPrevious">
    <keyboard-shortcut first-keystroke="up" />
    <keyboard-shortcut first-keystroke="ctrl p" />
  </action>
</keymap>